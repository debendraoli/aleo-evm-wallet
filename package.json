{
    "name": "evm-aleo-create-wallet",
    "version": "0.1.0",
    "description": "CLI to create, import, and export EVM and Aleo wallets",
    "bin": {
        "wallet-cli": "dist/cli.js"
    },
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json && node scripts/fix-shebang.cjs",
        "dev": "tsx src/cli.ts --help",
        "start": "node dist/cli.js",
        "lint": "eslint . --ext .ts",
        "test": "node dist/cli.js --version"
    },
    "keywords": [
        "evm",
        "aleo",
        "wallet",
        "cli",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "@provablehq/sdk": "^0.9.5",
        "chalk": "^5.3.0",
        "commander": "^12.1.0",
        "ethers": "^6.13.4",
        "inquirer": "^12.9.3"
    },
    "devDependencies": {
        "@types/node": "^22.5.4",
        "@typescript-eslint/eslint-plugin": "^8.4.0",
        "@typescript-eslint/parser": "^8.4.0",
        "eslint": "^9.10.0",
        "tsx": "^4.16.2",
        "typescript": "^5.5.4"
    }
}
